---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="TTB Aerospace">
  <!-- Starfield background -->
  <div id="starfield" aria-hidden="true"></div>


  <!-- Navigation -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#hero" class="hover:opacity-80 transition-opacity">
        <img src="/images/logo-new.png" alt="TTB Aerospace" class="h-12 w-auto" />
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#vehicle" data-section="vehicle" class="nav-link text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Vehicle</a>
        <a href="#avionics" data-section="avionics" class="nav-link text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Avionics</a>
        <a href="#hardware" data-section="hardware" class="nav-link text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Hardware</a>
        <a href="#featured" data-section="featured" class="nav-link text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Featured</a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-bg-primary)]/95 backdrop-blur-sm border-t border-[var(--color-surface-border)]">
      <div class="px-6 py-4 flex flex-col gap-4">
        <a href="#vehicle" class="text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Vehicle</a>
        <a href="#avionics" class="text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Avionics</a>
        <a href="#hardware" class="text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Hardware</a>
        <a href="#featured" class="text-sm text-[var(--color-text-secondary)] hover:text-white transition-colors uppercase tracking-widest">Featured</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section — Compact on mobile, video background on desktop -->
  <section id="hero" class="relative pt-28 pb-0 md:pt-0 md:pb-0 md:h-screen flex flex-col items-center justify-center overflow-hidden">
    <!-- Video background (desktop only) -->
    <div class="absolute inset-0 z-0 hidden md:block">
      <div class="absolute inset-0 bg-black/50 z-10"></div>
      <div id="hero-video-wrapper" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] pointer-events-none">
        <div id="hero-yt-player" class="w-full h-full"></div>
      </div>
    </div>
    <!-- Hero content -->
    <div class="relative z-20 text-center px-6">
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-bold mb-4 tracking-tight" style="font-family: var(--font-heading)">TTB AEROSPACE</h1>
      <p id="hero-subtitle" class="text-[var(--color-text-secondary)] text-lg md:text-xl tracking-wide max-w-2xl mx-auto" style="font-family: var(--font-heading)">
        <span id="typed-text"></span><span class="typed-cursor"></span>
      </p>
    </div>
    <!-- Scroll indicator (desktop only) -->
    <div class="absolute bottom-6 z-20 hidden md:flex flex-col items-center gap-2 animate-bounce">
      <span class="text-[var(--color-text-secondary)] text-xs uppercase tracking-widest" style="font-family: var(--font-mono)">Scroll</span>
      <svg class="w-4 h-4 text-[var(--color-text-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Vehicle Section — LLL info left, 3D rocket right -->
  <section id="vehicle" class="py-16 px-6 bg-transparent">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10 reveal">
        <p class="text-[var(--color-accent)] text-sm uppercase tracking-widest mb-3" style="font-family: var(--font-mono)">01 // Vehicle</p>
        <h2 class="text-4xl md:text-5xl font-bold mb-4" style="font-family: var(--font-heading)">LLL Rocket</h2>
        <div class="w-20 h-0.5 bg-[var(--color-accent)] accent-line"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 items-start">
        <!-- Left: All LLL info -->
        <div class="reveal">
          <p class="text-[var(--color-accent)] text-sm mb-4" style="font-family: var(--font-mono)">Primary Landing Vehicle</p>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-2">
            First ever rocket to vertically land with no throttle control, and second ever with solid fuel.
          </p>
          <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6">
            With 2 vertical landings, it is the highest reliability landing model rocket ever designed.
          </p>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-4 mb-6 reveal-stagger">
            <div class="bg-[#151515] border border-[var(--color-surface-border)] rounded-lg p-4 text-center">
              <p class="text-base md:text-2xl font-bold text-white counter-value" data-target="650" data-suffix="g" style="font-family: var(--font-heading)">650g</p>
              <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family: var(--font-mono)">Dry Mass</p>
            </div>
            <div class="bg-[#151515] border border-[var(--color-surface-border)] rounded-lg p-4 text-center">
              <p class="text-base md:text-2xl font-bold text-white counter-value" data-target="0.056" data-decimals="3" style="font-family: var(--font-heading)">0.056</p>
              <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family: var(--font-mono)">MMOI kg/m²</p>
            </div>
            <div class="bg-[#151515] border border-[var(--color-surface-border)] rounded-lg p-4 text-center">
              <p class="text-base md:text-2xl font-bold text-white counter-value" data-target="80" data-suffix="cm" style="font-family: var(--font-heading)">80cm</p>
              <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family: var(--font-mono)">Length</p>
            </div>
          </div>

          <!-- Flight Log -->
          <div class="bg-black border border-[var(--color-surface-border)] rounded-lg p-5">
            <h4 class="text-lg font-semibold mb-3" style="font-family: var(--font-heading)">Flight Log</h4>
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[var(--color-surface-border)]">
                  <th class="py-1.5 pr-3 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Flight</th>
                  <th class="py-1.5 pr-3 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Result</th>
                  <th class="py-1.5 pr-3 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Motors</th>
                  <th class="py-1.5 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Notes</th>
                </tr>
              </thead>
              <tbody class="text-sm">
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-1</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-2</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-3</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-4</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-5</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-6</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">LT-7</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
                <tr class="border-b border-[var(--color-surface-border)]/50">
                  <td class="py-1.5 pr-3 text-white">LT-8</td>
                  <td class="py-1.5 pr-3 text-green-500">Vertical Landing</td>
                  <td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td>
                  <td class="py-1.5"><a href="https://www.youtube.com/watch?v=1GanrexRyVY&t=41s" target="_blank" rel="noopener" class="text-[var(--color-accent)] hover:text-[var(--color-accent-bright)] transition-colors">Watch →</a></td>
                </tr>
                <tr><td class="py-1.5 pr-3 text-white">LT-9</td><td class="py-1.5 pr-3 text-green-500">Vertical Landing</td><td class="py-1.5 pr-3 text-[var(--color-text-secondary)]">2x Estes E12</td><td class="py-1.5 text-[var(--color-text-secondary)]">—</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Right: Interactive 3D Rocket Viewer -->
        <div class="reveal lg:sticky lg:top-20 lg:-mt-20">
          <div id="rocket-container" class="relative w-full aspect-[5/6] bg-[#111111] border border-[var(--color-surface-border)] rounded-xl overflow-hidden">
            <canvas id="rocket-canvas" class="w-full h-full"></canvas>
            <!-- Loading overlay -->
            <div id="loading-overlay" class="absolute inset-0 flex flex-col items-center justify-center bg-[var(--color-bg-primary)]">
              <div class="w-12 h-12 border-2 border-[var(--color-accent-dark)] border-t-[var(--color-accent)] rounded-full animate-spin mb-4"></div>
              <p class="text-[var(--color-text-secondary)] text-sm tracking-widest uppercase" style="font-family: var(--font-mono)">Loading Model</p>
            </div>
            <!-- Floating description that follows cursor (left side on desktop) -->
            <div id="hover-tooltip" class="absolute pointer-events-none opacity-0 transition-all duration-200 z-20" style="max-width: 220px;">
              <div class="bg-black/90 backdrop-blur-sm border border-[var(--color-surface-border)] rounded-lg p-3">
                <p id="tooltip-title" class="text-white font-semibold text-sm mb-1" style="font-family: var(--font-heading)"></p>
                <p id="tooltip-desc" class="text-[var(--color-text-secondary)] text-xs leading-relaxed" style="font-family: var(--font-mono)"></p>
                <p id="tooltip-link" class="text-[var(--color-accent)] text-xs mt-2 hidden" style="font-family: var(--font-mono)"></p>
              </div>
            </div>
          </div>
          <p class="text-[var(--color-text-secondary)] text-xs mt-3 text-center" style="font-family: var(--font-mono)">Hover over the model to explore components. Drag to rotate.</p>
        </div>
      </div>

      <!-- Alto B Rocket (below) -->
      <div class="mt-16 reveal">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <h3 class="text-2xl font-semibold mb-2" style="font-family: var(--font-heading)">Alto B Rocket</h3>
            <p class="text-[var(--color-accent)] text-sm mb-6" style="font-family: var(--font-mono)">High-Performance Vehicle</p>
            <p class="text-[var(--color-text-secondary)] leading-relaxed mb-6">
              Successor to Alto A, 50% longer, designed for higher and faster flights.
            </p>
            <div class="grid grid-cols-3 gap-4 mb-6 reveal-stagger">
              <div class="bg-[#151515] border border-[var(--color-surface-border)] rounded-lg p-4 text-center">
                <p class="text-base md:text-2xl font-bold text-white counter-value" data-target="615" data-suffix="g" style="font-family: var(--font-heading)">615g</p>
                <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family: var(--font-mono)">Dry Mass</p>
              </div>
              <div class="bg-[#151515] border border-[var(--color-surface-border)] rounded-lg p-4 text-center">
                <p class="text-base md:text-2xl font-bold text-white counter-value" data-target="0.060" data-decimals="3" style="font-family: var(--font-heading)">0.060</p>
                <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family: var(--font-mono)">MMOI kg/m²</p>
              </div>
              <div class="bg-[#151515] border border-[var(--color-surface-border)] rounded-lg p-4 text-center">
                <p class="text-base md:text-2xl font-bold text-white counter-value" data-target="75" data-suffix="cm" style="font-family: var(--font-heading)">75cm</p>
                <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family: var(--font-mono)">Length</p>
              </div>
            </div>
            <div class="bg-black border border-[var(--color-surface-border)] rounded-lg p-5">
              <h4 class="text-lg font-semibold mb-3" style="font-family: var(--font-heading)">Flight Log</h4>
              <table class="w-full text-left">
                <thead>
                  <tr class="border-b border-[var(--color-surface-border)]">
                    <th class="py-1.5 pr-3 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Flight</th>
                    <th class="py-1.5 pr-3 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Result</th>
                    <th class="py-1.5 text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Motors</th>
                  </tr>
                </thead>
                <tbody class="text-sm">
                  <tr class="border-b border-[var(--color-surface-border)]/50"><td class="py-1.5 pr-3 text-white">B TF-1</td><td class="py-1.5 pr-3 text-green-500">Success</td><td class="py-1.5 text-[var(--color-text-secondary)]">Estes E12</td></tr>
                  <tr><td class="py-1.5 pr-3 text-white">B TF-2</td><td class="py-1.5 pr-3 text-yellow-500">Partial Success</td><td class="py-1.5 text-[var(--color-text-secondary)]">Apogee F10</td></tr>
                </tbody>
              </table>
            </div>
          </div>
          <div>
            <div class="w-full bg-[var(--color-surface)] border border-[var(--color-surface-border)] rounded-xl overflow-hidden">
              <img src="/images/alto-b.webp" alt="Alto B Rocket Launch" class="w-full h-auto object-contain" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Avionics Section -->
  <section id="avionics" class="py-16 px-6 bg-[#1a1a1a]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 reveal">
        <p class="text-[var(--color-accent)] text-sm uppercase tracking-widest mb-3" style="font-family: var(--font-mono)">02 // Avionics</p>
        <h2 class="text-4xl md:text-5xl font-bold mb-4" style="font-family: var(--font-heading)">Flight Computers</h2>
        <div class="w-20 h-0.5 bg-[var(--color-accent)] accent-line"></div>
      </div>

      <div class="reveal grid md:grid-cols-[280px_1fr] gap-6">
        <!-- Left: Avionics selector stack -->
        <div class="flex flex-col gap-3">
          <button class="avionics-tab text-left p-4 rounded-lg border transition-all duration-200 hover:border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 border-[var(--color-accent)]/40" data-avionics="orbiton">
            <h3 class="text-base font-semibold text-white" style="font-family: var(--font-heading)">Aurora Orbiton</h3>
            <p class="text-xs text-[var(--color-accent)]" style="font-family: var(--font-mono)">2025 — Latest</p>
          </button>
          <button class="avionics-tab text-left p-4 rounded-lg border transition-all duration-200 hover:border-[var(--color-accent)]/30 bg-[var(--color-surface)] border-[var(--color-surface-border)]" data-avionics="pv1">
            <h3 class="text-base font-semibold text-white" style="font-family: var(--font-heading)">Aurora PV1</h3>
            <p class="text-xs text-[var(--color-text-secondary)]" style="font-family: var(--font-mono)">2021</p>
          </button>
          <button class="avionics-tab text-left p-4 rounded-lg border transition-all duration-200 hover:border-[var(--color-accent)]/30 bg-[var(--color-surface)] border-[var(--color-surface-border)]" data-avionics="dv5">
            <h3 class="text-base font-semibold text-white" style="font-family: var(--font-heading)">Aurora DV5</h3>
            <p class="text-xs text-[var(--color-text-secondary)]" style="font-family: var(--font-mono)">2021</p>
          </button>
        </div>

        <!-- Right: Avionics detail panels -->
        <div class="relative">
          <!-- Aurora Orbiton -->
          <div class="avionics-panel bg-[#151515] border border-[var(--color-surface-border)] rounded-xl p-6" id="panel-orbiton">
            <div class="flex items-center justify-between mb-5 flex-wrap gap-3">
              <div>
                <h3 class="text-xl font-semibold" style="font-family: var(--font-heading)">Aurora Orbiton Edition</h3>
                <p class="text-[var(--color-accent)] text-sm mt-1" style="font-family: var(--font-mono)">2025 — Latest Generation</p>
              </div>
              <span class="px-3 py-1 bg-green-500/20 border border-green-500/30 rounded-full text-xs text-green-400" style="font-family: var(--font-mono)">ACTIVE</span>
            </div>
            <div>
              <h4 class="text-sm text-[var(--color-text-secondary)] uppercase tracking-wider mb-3" style="font-family: var(--font-mono)">Specifications</h4>
              <ul class="space-y-2 text-sm mb-5">
                <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]"><span class="text-white">STM32H7</span> — 600MHz</span></li>
                <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]"><span class="text-white">BMI055/088</span> IMU + <span class="text-white">BMP390L</span> Baro</span></li>
                <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]"><span class="text-white">H3LIS</span> High-G Accelerometer</span></li>
                <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]">Flash logging, <span class="text-white">8 servos</span>, <span class="text-white">4 pyro</span></span></li>
                <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]"><span class="text-white">TPS259830</span> power — 20A</span></li>
                <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]"><span class="text-white">83×44mm</span>, USB-C</span></li>
              </ul>
              <div class="grid md:grid-cols-2 gap-4 h-80">
                <!-- 3D viewer (desktop only) -->
                <div id="orbiton-viewer" class="relative bg-[#111111] border border-[var(--color-surface-border)] rounded-lg overflow-hidden h-full hidden md:block">
                  <canvas id="orbiton-canvas" class="w-full h-full cursor-grab"></canvas>
                  <div id="orbiton-loading" class="absolute inset-0 flex items-center justify-center">
                    <p class="text-[var(--color-text-secondary)] text-sm" style="font-family: var(--font-mono)">Loading PCB...</p>
                  </div>
                  <div id="orbiton-tooltip" class="pointer-events-none absolute z-10 px-3 py-1.5 bg-black/80 border border-[var(--color-accent)]/30 rounded text-xs text-white opacity-0 transition-opacity duration-150 whitespace-nowrap" style="font-family: var(--font-mono)">
                    <span id="orbiton-tooltip-title"></span>
                  </div>
                </div>
                <div class="rounded-lg border border-[var(--color-surface-border)] overflow-hidden bg-black/30 h-full">
                  <img src="/images/orbiton-pcb.png" alt="Aurora Orbiton PCB Layout" class="w-full h-full object-contain" />
                </div>
              </div>
            </div>
          </div>

          <!-- Aurora PV1 -->
          <div class="avionics-panel bg-[#151515] border border-[var(--color-surface-border)] rounded-xl p-6 hidden" id="panel-pv1">
            <div class="flex items-center justify-between mb-5 flex-wrap gap-3">
              <div>
                <h3 class="text-xl font-semibold" style="font-family: var(--font-heading)">Aurora PV1</h3>
                <p class="text-[var(--color-accent)] text-sm mt-1" style="font-family: var(--font-mono)">2021</p>
              </div>
              <span class="px-3 py-1 bg-red-500/20 border border-red-500/30 rounded-full text-xs text-red-400" style="font-family: var(--font-mono)">INACTIVE</span>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="text-sm text-[var(--color-text-secondary)] uppercase tracking-wider mb-3" style="font-family: var(--font-mono)">Specifications</h4>
                <ul class="space-y-2 text-sm">
                  <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]"><span class="text-white">ATSAMD21G18A</span> processor</span></li>
                  <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]">BMI055/088 IMU, MS5607/11 Baro</span></li>
                  <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]">H3LIS accelerometer</span></li>
                  <li class="flex gap-3"><span class="text-[var(--color-accent)]">▸</span><span class="text-[var(--color-text-secondary)]">SD logging, 3 servos, 2 pyro</span></li>
