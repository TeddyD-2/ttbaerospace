  <!-- Starfield Script -->
  <script is:inline>
    (function() {
      var container = document.getElementById('starfield');
      if (!container) return;
      var canvas = document.createElement('canvas');
      canvas.style.width = '100%';
      canvas.style.height = '100%';
      container.appendChild(canvas);
      var ctx = canvas.getContext('2d');

      var NUM_STARS = 48;
      var canvasW, canvasH, dpr;

      function resize() {
        dpr = window.devicePixelRatio || 1;
        canvasW = window.innerWidth;
        canvasH = window.innerHeight;
        canvas.width = canvasW * dpr;
        canvas.height = canvasH * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      resize();
      window.addEventListener('resize', resize);

      // Stars drift linearly with slight gentle drift changes
      var stars = [];
      for (var i = 0; i < NUM_STARS; i++) {
        // Random speed — steep falloff: most stars slow, very few fast
        var r = Math.random();
        var speed = r * r * r * 1.5 + 0.05;
        var dir = Math.random() * Math.PI * 2;
        stars.push({
          x: Math.random() * canvasW,
          y: Math.random() * canvasH,
          vx: Math.cos(dir) * speed,
          vy: Math.sin(dir) * speed,
          drift: (Math.random() - 0.5) * 0.002, // very slight turn rate
          size: Math.random() * 1.2 + 0.3,
          opacity: Math.random() * 0.4 + 0.6,
          prevX: 0,
          prevY: 0
        });
      }

      function draw() {
        if (document.hidden) { requestAnimationFrame(draw); return; }
        ctx.clearRect(0, 0, canvasW, canvasH);
        for (var i = 0; i < stars.length; i++) {
          var s = stars[i];
          // Gentle drift: slowly rotate velocity direction
          var cosD = Math.cos(s.drift);
          var sinD = Math.sin(s.drift);
          var nvx = s.vx * cosD - s.vy * sinD;
          var nvy = s.vx * sinD + s.vy * cosD;
          s.vx = nvx;
          s.vy = nvy;
          // Move
          s.x += s.vx;
          s.y += s.vy;
          // Wrap around screen
          if (s.x < 0) s.x += canvasW;
          if (s.x > canvasW) s.x -= canvasW;
          if (s.y < 0) s.y += canvasH;
          if (s.y > canvasH) s.y -= canvasH;
          var x = s.x;
          var y = s.y;

          // Trail based on velocity
          var pxSpeed = Math.sqrt(s.vx * s.vx + s.vy * s.vy);

          if (pxSpeed > 0.3) {
            var trailLen = Math.min(pxSpeed * 6, 60);
            var tx = x - (s.vx / pxSpeed) * trailLen;
            var ty = y - (s.vy / pxSpeed) * trailLen;

            // Gradient trail: bright at head, fades to nothing
            var grad = ctx.createLinearGradient(tx, ty, x, y);
            grad.addColorStop(0, 'rgba(255, 255, 255, 0)');
            grad.addColorStop(1, 'rgba(255, 255, 255, ' + (s.opacity * 0.8).toFixed(2) + ')');
            ctx.beginPath();
            ctx.moveTo(tx, ty);
            ctx.lineTo(x, y);
            ctx.strokeStyle = grad;
            ctx.lineWidth = s.size * 1.2;
            ctx.lineCap = 'round';
            ctx.stroke();
          }

          // Draw star dot
          ctx.beginPath();
          ctx.arc(x, y, s.size, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255, 255, 255, ' + s.opacity.toFixed(2) + ')';
          ctx.fill();

        }
        requestAnimationFrame(draw);
      }
      draw();
    })();
  </script>

  <!-- Three.js Script — Rocket Viewer in Vehicle Section -->
  <script>
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    // Component group definitions — keyed by group ID
    const componentInfo: Record<string, { name: string; desc: string; link?: string; linkLabel?: string; onNavigate?: () => void }> = {
      legs: {
        name: 'Landing Legs',
        desc: '4 deployable landing legs with spring-loaded deployment mechanism. 3D printed (PLA).',
      },
      avionics: {
        name: 'Avionics Bay',
        desc: 'Aurora PV1 — ATSAMD21G18A, BMI055/088 IMU, MS5607/11 baro, 3 servo outputs, 2 pyro channels.',
        link: '#avionics',
        linkLabel: 'View Avionics →',
        onNavigate: () => {
          // Click the PV1 tab when navigating
          const pv1Tab = document.querySelector('[data-avionics="pv1"]') as HTMLElement;
          if (pv1Tab) pv1Tab.click();
        },
      },
      tvc: {
        name: 'TVC Mount',
        desc: 'Dual motor thrust vector control. ±5° actuation via MKS HV393i servos at 0.05s/5°. MATLAB/Simulink characterized.',
        link: '#hardware',
        linkLabel: 'View Hardware →',
      },
      nosecone: {
        name: 'Nosecone',
        desc: '3D printed nosecone with aerodynamic profile for stable ascent.',
      },
    };

    const isMobile = window.innerWidth < 768;

    const canvas = document.getElementById('rocket-canvas') as HTMLCanvasElement;
    const container = document.getElementById('rocket-container')!;
    const loadingOverlay = document.getElementById('loading-overlay')!;
    const hoverTooltip = document.getElementById('hover-tooltip')!;
    const tooltipTitle = document.getElementById('tooltip-title')!;
    const tooltipDesc = document.getElementById('tooltip-desc')!;
    const tooltipLink = document.getElementById('tooltip-link')!;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.01, 100);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: !isMobile, alpha: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
    renderer.setClearColor(0x000000, 0);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.5;
    controls.enablePan = false;
    controls.enableZoom = false;
    controls.minPolarAngle = Math.PI * 0.2;
    controls.maxPolarAngle = Math.PI * 0.8;

    // Lighting
    scene.add(new THREE.AmbientLight(0xffffff, 0.8));
    const keyLight = new THREE.DirectionalLight(0xffffff, 1.0);
    keyLight.position.set(3, 4, 2);
    scene.add(keyLight);
    const fillLight = new THREE.DirectionalLight(0xffffff, 0.4);
    fillLight.position.set(-2, 1, -1);
    scene.add(fillLight);

    // Materials
    const tubeMaterial = new THREE.MeshPhongMaterial({
      color: 0x888888, transparent: true, opacity: 0.06,
      side: THREE.DoubleSide, depthWrite: false,
    });
    const internalMaterial = new THREE.MeshPhongMaterial({
      color: 0x333333, shininess: 40, specular: 0x222222,
    });
    const internalHighlightMaterial = new THREE.MeshPhongMaterial({
      color: 0xcc0000, shininess: 60, emissive: 0x220000,
    });

    // Mesh tracking
    const allMeshes: THREE.Mesh[] = [];
    const airframeMeshes = new Set<THREE.Mesh>();
    const raycastTargets: THREE.Mesh[] = []; // excludes airframe
    const meshToGroup = new Map<THREE.Mesh, string>(); // mesh → group ID
    const groupMeshes = new Map<string, THREE.Mesh[]>(); // group ID → meshes
    const originalMaterials = new Map<THREE.Mesh, THREE.Material>();

    // White default material for avionics/TVC (idle state)
    const whiteIdleMaterial = new THREE.MeshPhongMaterial({
      color: 0xcccccc, shininess: 50, specular: 0x444444,
    });

    // Tag all descendant meshes of a node with a group
    function tagDescendants(node: THREE.Object3D, group: string) {
      node.traverse((child) => {
        if ((child as THREE.Mesh).isMesh) {
          const m = child as THREE.Mesh;
          if (!meshToGroup.has(m)) {
            meshToGroup.set(m, group);
            if (!groupMeshes.has(group)) groupMeshes.set(group, []);
            groupMeshes.get(group)!.push(m);
          }
        }
      });
    }

    // Classify nodes — check name prefixes, must check more specific names first
    // Note: GLTF from Onshape uses underscores in names (e.g. LLL_Mount_Assembly_<1>)
    function classifyNodeName(name: string): string | null {
      if (name === 'airframe' || name === 'occurrence_of_airframe') return 'airframe';
      if (name === 'nosecone' || name === 'occurrence_of_nosecone') return 'nosecone';
      // LLL_Mount_Assembly MUST come before Mount_Assembly
      if (name.startsWith('LLL_Mount_Assembly')) return 'avionics';
      if (name.startsWith('Mount_Assembly')) return 'tvc';
      if (name.startsWith('SG90')) return 'tvc';
      if (name.startsWith('R2_Landing_Leg') || name.startsWith('R2_Bottom_Strut')) return 'legs';
      if (name.startsWith('Upper_Strut')) return 'legs';
      if (name.includes('Top_leg_strut')) return 'legs';
      return null;
    }

    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();

    let rocketPivot: THREE.Group | null = null;
    const loader = new GLTFLoader();
    // Lazy-load: only fetch model when container is near viewport
    let rocketModelLoaded = false;
    function loadRocketModel() {
      if (rocketModelLoaded) return;
      rocketModelLoaded = true;
      loader.load(
        '/models/rocket.gltf',
      (gltf) => {
        const model = gltf.scene;

        // Step 1: Find assembly nodes by name and tag all their descendant meshes
        const processNode = (node: THREE.Object3D) => {
          const group = classifyNodeName(node.name);
          if (group) {
            console.log(`Tagging "${node.name}" as ${group}`);
            tagDescendants(node, group);
          } else {
            // Only recurse into children if this node wasn't classified
            // (if classified, tagDescendants already handled all descendants)
            node.children.forEach(child => processNode(child));
          }
        };
        processNode(model);

        // Step 2: Collect all meshes and apply materials
        model.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            const m = child as THREE.Mesh;
            const group = meshToGroup.get(m) || null;
            const isAirframe = group === 'airframe';

            // Avionics and TVC start white (idle highlight)
            let mat: THREE.Material;
            if (isAirframe) {
              mat = tubeMaterial.clone();
            } else if (group === 'avionics' || group === 'tvc' || group === 'legs') {
              mat = whiteIdleMaterial.clone();
            } else {
              mat = internalMaterial.clone();
            }

            originalMaterials.set(m, mat);
            m.material = mat;
            allMeshes.push(m);

            if (isAirframe) {
              airframeMeshes.add(m);
              m.renderOrder = 1;
            } else {
              raycastTargets.push(m);
            }
          }
        });

        console.log('Group counts:', [...groupMeshes.entries()].map(([k, v]) => `${k}: ${v.length}`).join(', '));
        console.log('Total meshes:', allMeshes.length);
        console.log('Unclassified:', allMeshes.filter(m => !meshToGroup.has(m)).length);

        // Center and orient
        const preBox = new THREE.Box3().setFromObject(model);
        const preCenter = preBox.getCenter(new THREE.Vector3());
        model.position.set(-preCenter.x, -preCenter.y, -preCenter.z);

        rocketPivot = new THREE.Group();
        rocketPivot.add(model);
        const preSize = preBox.getSize(new THREE.Vector3());
        if (preSize.x > preSize.y && preSize.x > preSize.z) {
          rocketPivot.rotation.z = Math.PI / 2;
        } else if (preSize.z > preSize.y && preSize.z > preSize.x) {
          rocketPivot.rotation.x = -Math.PI / 2;
        }
        scene.add(rocketPivot);

        // Camera setup — focus on bottom third, zoomed in
        const box = new THREE.Box3().setFromObject(rocketPivot);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        const bottomThirdCenterY = box.min.y + size.y * 0.2;
        controls.target.set(center.x, bottomThirdCenterY, center.z);
        const dist = 0.9;
        camera.position.set(center.x + dist, bottomThirdCenterY + 0.05, center.z + dist * 0.4);
        controls.update();

        // Create invisible bounding-box hit areas for avionics and TVC
        // so the entire assembly volume is hoverable
        ['avionics', 'tvc'].forEach((groupId) => {
          const meshes = groupMeshes.get(groupId);
          if (!meshes || meshes.length === 0) return;
          const groupBox = new THREE.Box3();
          meshes.forEach((m) => groupBox.expandByObject(m));
          const groupSize = groupBox.getSize(new THREE.Vector3());
          const groupCenter = groupBox.getCenter(new THREE.Vector3());
          const pad = 0.03;
          const hitGeo = new THREE.BoxGeometry(groupSize.x + pad, groupSize.y + pad, groupSize.z + pad);
          const hitMat = new THREE.MeshBasicMaterial({ visible: false });
          const hitMesh = new THREE.Mesh(hitGeo, hitMat);
          hitMesh.position.copy(groupCenter);
          scene.add(hitMesh);
          raycastTargets.push(hitMesh);
          meshToGroup.set(hitMesh, groupId);
        });

        loadingOverlay.style.opacity = '0';
        loadingOverlay.style.transition = 'opacity 0.5s';
        setTimeout(() => { loadingOverlay.style.display = 'none'; }, 500);
      },
      undefined,
      (err) => {
        console.error('Failed to load model:', err);
        loadingOverlay.innerHTML = '<p class="text-red-500">Failed to load 3D model</p>';
      }
    );
    }
    // Trigger model load when container scrolls near viewport
    const rocketLoadObserver = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { loadRocketModel(); rocketLoadObserver.disconnect(); }
    }, { rootMargin: '200px' });
    rocketLoadObserver.observe(container);

    // Raycasting hover
    let currentGroup: string | null = null;

    function highlightGroup(group: string) {
      // Reset everything to original
      allMeshes.forEach((mesh) => {
        if (!airframeMeshes.has(mesh)) {
          mesh.material = originalMaterials.get(mesh) || internalMaterial;
        }
      });
      // Highlight the hovered group red
      const meshes = groupMeshes.get(group);
      if (meshes) {
        meshes.forEach((m) => { m.material = internalHighlightMaterial; });
      }
    }

    function clearHighlight() {
      allMeshes.forEach((mesh) => {
        mesh.material = originalMaterials.get(mesh) || internalMaterial;
      });
    }

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObjects(raycastTargets, false);

      // Position tooltip to the LEFT of cursor on desktop
      const containerRect = container.getBoundingClientRect();
      const cursorX = e.clientX - containerRect.left;
      const cursorY = e.clientY - containerRect.top;
      // Place tooltip to the left, or right if too close to left edge
      const tooltipW = 230;
      if (cursorX > tooltipW + 20) {
        hoverTooltip.style.left = (cursorX - tooltipW - 12) + 'px';
      } else {
        hoverTooltip.style.left = (cursorX + 16) + 'px';
      }
      hoverTooltip.style.top = (cursorY - 10) + 'px';

      if (intersects.length > 0) {
        const hit = intersects[0].object as THREE.Mesh;
        const group = meshToGroup.get(hit) || null;

        if (group && group !== currentGroup) {
          currentGroup = group;
          highlightGroup(group);

          const info = componentInfo[group];
          if (info) {
            tooltipTitle.textContent = info.name;
            tooltipDesc.textContent = info.desc;
            if (info.linkLabel) {
              tooltipLink.textContent = info.linkLabel;
              tooltipLink.classList.remove('hidden');
            } else {
              tooltipLink.classList.add('hidden');
            }
            hoverTooltip.style.opacity = '1';
          }
        }
        canvas.style.cursor = 'grab';
      } else {
        if (currentGroup !== null) {
          currentGroup = null;
          clearHighlight();
          hoverTooltip.style.opacity = '0';
        }
        canvas.style.cursor = 'grab';
      }
    });

    canvas.addEventListener('mouseleave', () => {
      currentGroup = null;
      clearHighlight();
      hoverTooltip.style.opacity = '0';
      canvas.style.cursor = 'grab';
    });

    // Click to navigate to section
    canvas.addEventListener('click', () => {
      if (isMobile) return; // Don't navigate on mobile — interferes with touch interaction
      if (currentGroup) {
        const info = componentInfo[currentGroup];
        if (info?.link) {
          if (info.onNavigate) info.onNavigate();
          document.querySelector(info.link)?.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });

    // Animation loop (continuous auto-rotate, pauses when off-screen)
    const worldY = new THREE.Vector3(0, 1, 0);
    let rocketVisible = false;
    const ROCKET_ROTATE_MAX = 0.008;
    let rocketRotateSpeed = ROCKET_ROTATE_MAX;
    let rocketHovered = false;
    canvas.addEventListener('mouseenter', () => { rocketHovered = true; });
    canvas.addEventListener('mouseleave', () => { rocketHovered = false; });
    new IntersectionObserver(([e]) => { rocketVisible = e.isIntersecting; }, { threshold: 0 }).observe(container);
    function animate() {
      requestAnimationFrame(animate);
      if (!rocketVisible) return;
      // Smoothly ease rotation speed toward target
      const target = rocketHovered ? 0 : ROCKET_ROTATE_MAX;
      rocketRotateSpeed += (target - rocketRotateSpeed) * 0.05;
      if (rocketPivot && rocketRotateSpeed > 0.0001) {
        rocketPivot.rotateOnWorldAxis(worldY, rocketRotateSpeed);
      }
      controls.update();
      renderer.render(scene, camera);
    }
    animate();

    // Resize
    window.addEventListener('resize', () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });



    // === TYPED TEXT EFFECT ===
    const typedEl = document.getElementById('typed-text')!;
    const typedText = 'Making and Launching Advanced Model Rocket Components';
    let charIndex = 0;
    function typeNext() {
      if (charIndex < typedText.length) {
        typedEl.textContent += typedText[charIndex];
        charIndex++;
        setTimeout(typeNext, 35 + Math.random() * 25);
      } else {
        // Remove cursor after typing is done
        const cursor = document.querySelector('.typed-cursor') as HTMLElement;
        if (cursor) setTimeout(() => { cursor.style.opacity = '0'; }, 1500);
      }
    }
    setTimeout(typeNext, 600);

    // === NAVBAR — scroll effect + active section indicator ===
    const navbar = document.getElementById('navbar')!;
    const navLinks = document.querySelectorAll('.nav-link') as NodeListOf<HTMLElement>;
    const sections = ['vehicle', 'avionics', 'hardware', 'featured'];
    navbar.style.backgroundColor = 'rgba(30, 30, 30, 0.5)';
    navbar.style.backdropFilter = 'blur(4px)';

    window.addEventListener('scroll', () => {
      // Navbar background
      const scrollFraction = Math.min(window.scrollY / 400, 1);
      const opacity = 0.5 + scrollFraction * 0.5;
      const bg = Math.round(30 - scrollFraction * 20);
      const blur = 4 + scrollFraction * 8;
      navbar.style.backgroundColor = `rgba(${bg}, ${bg}, ${bg}, ${opacity})`;
      navbar.style.backdropFilter = `blur(${blur}px)`;
      if (scrollFraction > 0.1) {
        navbar.style.borderBottom = `1px solid rgba(255,255,255,${scrollFraction * 0.05})`;
      } else {
        navbar.style.borderBottom = 'none';
      }

      // Active section indicator
      let currentSection = '';
      for (const id of sections) {
        const el = document.getElementById(id);
        if (el && window.scrollY >= el.offsetTop - 200) currentSection = id;
      }
      navLinks.forEach((link) => {
        if (link.dataset.section === currentSection) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });
    });

    // === MOBILE MENU ===
    document.getElementById('mobile-menu-btn')!.addEventListener('click', () => {
      document.getElementById('mobile-menu')!.classList.toggle('hidden');
    });
    document.querySelectorAll('#mobile-menu a').forEach((a) => {
      a.addEventListener('click', () => { document.getElementById('mobile-menu')!.classList.add('hidden'); });
    });

    // === AVIONICS TAB SWITCHING (crossfade) ===
    const avionicsTabs = document.querySelectorAll('.avionics-tab');
    const avionicsPanels = document.querySelectorAll('.avionics-panel');
    avionicsTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.avionics;
        avionicsTabs.forEach((t) => {
          const el = t as HTMLElement;
          if (el.dataset.avionics === target) {
            el.classList.remove('bg-[var(--color-surface)]', 'border-[var(--color-surface-border)]');
            el.classList.add('bg-[var(--color-accent)]/10', 'border-[var(--color-accent)]/40');
          } else {
            el.classList.remove('bg-[var(--color-accent)]/10', 'border-[var(--color-accent)]/40');
            el.classList.add('bg-[var(--color-surface)]', 'border-[var(--color-surface-border)]');
          }
        });
        avionicsPanels.forEach((p) => {
          const panel = p as HTMLElement;
          if (panel.id === `panel-${target}`) {
            panel.classList.remove('hidden');
            panel.classList.add('panel-entering');
            panel.addEventListener('animationend', () => panel.classList.remove('panel-entering'), { once: true });
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    // === CAROUSEL ===
    const carouselTrack = document.getElementById('carousel-track')!;
    const carouselDots = document.querySelectorAll('.carousel-dot');
    const slideCount = 4;
    let currentSlide = 0;

    function goToSlide(index: number) {
      currentSlide = ((index % slideCount) + slideCount) % slideCount;
      carouselTrack.style.transform = `translateX(-${currentSlide * 100}%)`;
      carouselDots.forEach((dot, i) => {
        if (i === currentSlide) {
          dot.classList.remove('bg-[var(--color-surface-border)]');
          dot.classList.add('bg-[var(--color-accent)]');
        } else {
          dot.classList.remove('bg-[var(--color-accent)]');
          dot.classList.add('bg-[var(--color-surface-border)]');
        }
      });
    }

    document.getElementById('carousel-prev')!.addEventListener('click', () => goToSlide(currentSlide - 1));
    document.getElementById('carousel-next')!.addEventListener('click', () => goToSlide(currentSlide + 1));
    carouselDots.forEach((dot) => {
      dot.addEventListener('click', () => goToSlide(Number((dot as HTMLElement).dataset.slide)));
    });

    // === SCROLL REVEAL (with stagger support) ===
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.opacity = '1';
          (entry.target as HTMLElement).style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach((el) => {
      (el as HTMLElement).style.opacity = '0';
      (el as HTMLElement).style.transform = 'translateY(30px)';
      (el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });

    // === STAGGERED REVEAL ===
    const staggerObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          // Add stagger delays to children
          Array.from(el.children).forEach((child, i) => {
            (child as HTMLElement).style.transitionDelay = `${i * 120}ms`;
          });
          el.classList.add('revealed');
          staggerObserver.unobserve(el);
        }
      });
    }, { threshold: 0.2 });

    document.querySelectorAll('.reveal-stagger').forEach((el) => staggerObserver.observe(el));

    // === ACCENT LINE DRAW-IN ===
    const lineObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).classList.add('drawn');
          lineObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('.accent-line').forEach((el) => lineObserver.observe(el));

    // === COUNTER ANIMATION ===
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseFloat(el.dataset.target || '0');
          const suffix = el.dataset.suffix || '';
          const decimals = parseInt(el.dataset.decimals || '0');
          const duration = 1200;
          const start = performance.now();

          function updateCounter(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // Ease out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            const current = target * eased;
            el.textContent = (decimals > 0 ? current.toFixed(decimals) : Math.round(current).toString()) + suffix;
            if (progress < 1) requestAnimationFrame(updateCounter);
          }
          requestAnimationFrame(updateCounter);
          counterObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('.counter-value').forEach((el) => counterObserver.observe(el));

  </script>

  <!-- TVC Mount 3D Viewer Script -->
  <script>
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    const tvcIsMobile = window.innerWidth < 768;

    const tvcContainer = document.getElementById('tvc-viewer')!;
    const tvcCanvas = document.getElementById('tvc-canvas') as HTMLCanvasElement;
    const tvcLoading = document.getElementById('tvc-loading')!;
    const tvcTooltip = document.getElementById('tvc-tooltip')!;
    const tvcTooltipTitle = document.getElementById('tvc-tooltip-title')!;

    const tvcScene = new THREE.Scene();
    const tvcCamera = new THREE.PerspectiveCamera(35, 1, 0.01, 10);
    const tvcRenderer = new THREE.WebGLRenderer({ canvas: tvcCanvas, antialias: !tvcIsMobile, alpha: true });
    tvcRenderer.setPixelRatio(Math.min(window.devicePixelRatio, tvcIsMobile ? 1.5 : 2));
    tvcRenderer.setSize(tvcContainer.clientWidth, tvcContainer.clientHeight);

    const tvcControls = new OrbitControls(tvcCamera, tvcCanvas);
    tvcControls.enableDamping = true;
    tvcControls.dampingFactor = 0.05;
    tvcControls.enablePan = false;

    // Lighting
    tvcScene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const tvcDirLight = new THREE.DirectionalLight(0xffffff, 1.0);
    tvcDirLight.position.set(2, 3, 2);
    tvcScene.add(tvcDirLight);
    const tvcDirLight2 = new THREE.DirectionalLight(0xffffff, 0.4);
    tvcDirLight2.position.set(-2, 1, -1);
    tvcScene.add(tvcDirLight2);

    // Materials
    const tvcRedMat = new THREE.MeshPhongMaterial({ color: 0xcc2222, shininess: 60, specular: 0x444444 });
    const tvcBeigeMat = new THREE.MeshPhongMaterial({ color: 0xd4b896, shininess: 30, specular: 0x222222 });
    const tvcWhiteMat = new THREE.MeshPhongMaterial({ color: 0xe8e8e8, shininess: 50, specular: 0x444444 });
    const tvcBlackMat = new THREE.MeshPhongMaterial({ color: 0x1a1a1a, shininess: 40, specular: 0x333333 });
    const tvcHighlightMat = new THREE.MeshPhongMaterial({ color: 0xff4444, shininess: 80, emissive: 0x331111, specular: 0x666666 });

    // Classify TVC parts by node name (uses underscores from Onshape GLTF)
    type TvcCategory = 'servo' | 'motor' | 'sleeve' | 'mount';
    function classifyTvcNode(name: string): TvcCategory | null {
      if (name.includes('HV93i')) return 'servo';
      if (name.includes('24mm_E12')) return 'motor';
      if (name.includes('E12_Sleeve')) return 'sleeve';
      if (name.includes('Gimbal_Mount') || name.includes('Motor_Tube')) return 'mount';
      return null;
    }

    const tvcCategoryInfo: Record<TvcCategory, { mat: THREE.Material; displayName: (name: string) => string }> = {
      servo: { mat: tvcRedMat, displayName: () => 'MKS HV93i Servo' },
      motor: { mat: tvcBeigeMat, displayName: () => 'Estes E12 Motor' },
      sleeve: { mat: tvcWhiteMat, displayName: (name) => name.replace(/^occurrence_of_/, '').replace(/_\d+$/, '').replace(/_/g, ' ') },
      mount: { mat: tvcBlackMat, displayName: (name) => name.replace(/^occurrence_of_/, '').replace(/_\d+$/, '').replace(/_/g, ' ') },
    };

    const tvcMeshes: THREE.Mesh[] = [];
    const tvcOriginalMats = new Map<THREE.Mesh, THREE.Material>();
    const tvcMeshNames = new Map<THREE.Mesh, string>();
    const tvcMeshToGroup = new Map<THREE.Mesh, string>(); // maps mesh to parent group name
    const tvcGroupMeshes = new Map<string, THREE.Mesh[]>();

    const tvcRaycaster = new THREE.Raycaster();
    const tvcMouse = new THREE.Vector2();

    function tagTvcDescendants(node: THREE.Object3D, category: TvcCategory, groupName: string) {
      node.traverse((child) => {
        if ((child as THREE.Mesh).isMesh) {
          const m = child as THREE.Mesh;
          if (!tvcMeshToGroup.has(m)) {
            const info = tvcCategoryInfo[category];
            m.material = info.mat.clone();
            tvcOriginalMats.set(m, m.material as THREE.Material);
            tvcMeshNames.set(m, info.displayName(groupName));
            tvcMeshToGroup.set(m, groupName);
            if (!tvcGroupMeshes.has(groupName)) tvcGroupMeshes.set(groupName, []);
            tvcGroupMeshes.get(groupName)!.push(m);
            tvcMeshes.push(m);
          }
        }
      });
    }

    let tvcPivot: THREE.Group | null = null;
    const tvcLoader = new GLTFLoader();
    let tvcModelLoaded = false;
    function loadTvcModel() {
      if (tvcModelLoaded) return;
      tvcModelLoaded = true;
      tvcLoader.load('/models/tvc-mount.gltf', (gltf) => {
      const model = gltf.scene;

      // Top-down classification: walk tree, tag descendants when we hit a named assembly
      const processTvcNode = (node: THREE.Object3D) => {
        const category = classifyTvcNode(node.name);
        if (category) {
          tagTvcDescendants(node, category, node.name);
        } else {
          node.children.forEach(child => processTvcNode(child));
        }
      };
      processTvcNode(model);
      // console.log('TVC groups:', [...tvcGroupMeshes.entries()].map(([k, v]) => `${k}: ${v.length}`).join(', '));

      // Center and orient
      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      model.position.set(-center.x, -center.y, -center.z);

      tvcPivot = new THREE.Group();
      tvcPivot.add(model);
      const size = box.getSize(new THREE.Vector3());
      if (size.x > size.y && size.x > size.z) {
        tvcPivot.rotation.z = Math.PI / 2;
      } else if (size.z > size.y && size.z > size.x) {
        tvcPivot.rotation.x = -Math.PI / 2;
      }
      tvcScene.add(tvcPivot);

      const finalBox = new THREE.Box3().setFromObject(tvcPivot);
      const finalCenter = finalBox.getCenter(new THREE.Vector3());
      const finalSize = finalBox.getSize(new THREE.Vector3());
      tvcControls.target.copy(finalCenter);
      const dist = Math.max(finalSize.x, finalSize.y, finalSize.z) * 2.5;
      tvcCamera.position.set(finalCenter.x + dist * 0.6, finalCenter.y + dist * 0.3, finalCenter.z + dist * 0.6);
      tvcControls.update();

      tvcLoading.style.opacity = '0';
      tvcLoading.style.transition = 'opacity 0.5s';
      setTimeout(() => { tvcLoading.style.display = 'none'; }, 500);
    },
    undefined,
    (error) => { console.error('TVC model load error:', error); }
    );
    }
    const tvcLoadObserver = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { loadTvcModel(); tvcLoadObserver.disconnect(); }
    }, { rootMargin: '200px' });
    tvcLoadObserver.observe(tvcContainer);

    // Hover — highlight entire group (all meshes sharing same parent part)
    let tvcCurrentGroup: string | null = null;

    function tvcHighlightGroup(groupName: string) {
      // Restore all to original
      tvcMeshes.forEach(m => { m.material = tvcOriginalMats.get(m) || tvcBlackMat; });
      // Highlight group
      const meshes = tvcGroupMeshes.get(groupName);
      if (meshes) meshes.forEach(m => { m.material = tvcHighlightMat; });
    }

    function tvcClearHighlight() {
      tvcMeshes.forEach(m => { m.material = tvcOriginalMats.get(m) || tvcBlackMat; });
    }

    tvcCanvas.addEventListener('mousemove', (e) => {
      const rect = tvcCanvas.getBoundingClientRect();
      tvcMouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      tvcMouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

      tvcRaycaster.setFromCamera(tvcMouse, tvcCamera);
      const intersects = tvcRaycaster.intersectObjects(tvcMeshes, false);

      const containerRect = tvcContainer.getBoundingClientRect();
      const cx = e.clientX - containerRect.left;
      const cy = e.clientY - containerRect.top;
      tvcTooltip.style.left = (cx + 16) + 'px';
      tvcTooltip.style.top = (cy - 10) + 'px';

      if (intersects.length > 0) {
        const hit = intersects[0].object as THREE.Mesh;
        const groupName = tvcMeshToGroup.get(hit) || null;
        if (groupName && groupName !== tvcCurrentGroup) {
          tvcCurrentGroup = groupName;
          tvcHighlightGroup(groupName);
          tvcTooltipTitle.textContent = tvcMeshNames.get(hit) || hit.name;
          tvcTooltip.style.opacity = '1';
        }
        tvcCanvas.style.cursor = 'pointer';
      } else {
        if (tvcCurrentGroup) {
          tvcCurrentGroup = null;
          tvcClearHighlight();
          tvcTooltip.style.opacity = '0';
        }
        tvcCanvas.style.cursor = 'grab';
      }
    });

    tvcCanvas.addEventListener('mouseleave', () => {
      if (tvcCurrentGroup) {
        tvcCurrentGroup = null;
        tvcClearHighlight();
      }
      tvcTooltip.style.opacity = '0';
      tvcCanvas.style.cursor = 'grab';
    });

    // Animation loop (continuous auto-rotate, pauses when off-screen)
    const tvcWorldY = new THREE.Vector3(0, 1, 0);
    let tvcVisible = false;
    const TVC_ROTATE_MAX = 0.008;
    let tvcRotateSpeed = TVC_ROTATE_MAX;
    let tvcHovered = false;
    tvcCanvas.addEventListener('mouseenter', () => { tvcHovered = true; });
    tvcCanvas.addEventListener('mouseleave', () => { tvcHovered = false; });
    new IntersectionObserver(([e]) => { tvcVisible = e.isIntersecting; }, { threshold: 0 }).observe(tvcContainer);
    function tvcAnimate() {
      requestAnimationFrame(tvcAnimate);
      if (!tvcVisible) return;
      const target = tvcHovered ? 0 : TVC_ROTATE_MAX;
      tvcRotateSpeed += (target - tvcRotateSpeed) * 0.05;
      if (tvcPivot && tvcRotateSpeed > 0.0001) {
        tvcPivot.rotateOnWorldAxis(tvcWorldY, tvcRotateSpeed);
      }
      tvcControls.update();
      tvcRenderer.render(tvcScene, tvcCamera);
    }
    tvcAnimate();

    // Resize
    new ResizeObserver(() => {
      const w = tvcContainer.clientWidth;
      const h = tvcContainer.clientHeight;
      tvcCamera.aspect = w / h;
      tvcCamera.updateProjectionMatrix();
      tvcRenderer.setSize(w, h);
    }).observe(tvcContainer);
  </script>

  <!-- Orbiton PCB 3D Viewer Script (desktop only) -->
  <script>
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    // Skip entire 3D viewer on mobile
    if (window.innerWidth >= 768) {

    const pcbContainer = document.getElementById('orbiton-viewer')!;
    const pcbCanvas = document.getElementById('orbiton-canvas') as HTMLCanvasElement;
    const pcbLoading = document.getElementById('orbiton-loading')!;
    const pcbTooltip = document.getElementById('orbiton-tooltip')!;
    const pcbTooltipTitle = document.getElementById('orbiton-tooltip-title')!;

    const pcbScene = new THREE.Scene();
    const pcbCamera = new THREE.PerspectiveCamera(35, 1, 0.01, 100);
    const pcbRenderer = new THREE.WebGLRenderer({ canvas: pcbCanvas, antialias: true, alpha: true });
    pcbRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    pcbRenderer.setSize(pcbContainer.clientWidth, pcbContainer.clientHeight);
    pcbRenderer.toneMapping = THREE.LinearToneMapping;
    pcbRenderer.toneMappingExposure = 1.0;
    pcbRenderer.shadowMap.enabled = true;
    pcbRenderer.shadowMap.type = THREE.VSMShadowMap;

    const pcbControls = new OrbitControls(pcbCamera, pcbCanvas);
    pcbControls.enableDamping = true;
    pcbControls.dampingFactor = 0.08;
    pcbControls.enablePan = false;
    pcbControls.autoRotate = false;
    pcbControls.minDistance = 0.01;
    pcbControls.maxDistance = 50;

    // Environment map for realistic reflections
    const pcbPmrem = new THREE.PMREMGenerator(pcbRenderer);
    pcbPmrem.compileEquirectangularShader();
    const envScene = new THREE.Scene();
    const envGeo = new THREE.SphereGeometry(10, 32, 16);
    const envMat = new THREE.ShaderMaterial({
      side: THREE.BackSide,
      uniforms: {},
      vertexShader: `
        varying vec3 vWorldPos;
        void main() {
          vWorldPos = (modelMatrix * vec4(position, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        varying vec3 vWorldPos;
        void main() {
          float y = normalize(vWorldPos).y;
          vec3 top = vec3(0.95, 0.92, 0.88);
          vec3 mid = vec3(0.12, 0.12, 0.14);
          vec3 bot = vec3(0.06, 0.07, 0.10);
          vec3 col = y > 0.0 ? mix(mid, top, pow(y, 0.4)) : mix(mid, bot, pow(-y, 0.6));
          float side = abs(normalize(vWorldPos).x);
          col += vec3(0.15, 0.06, 0.02) * pow(side, 3.0) * (1.0 - abs(y));
          gl_FragColor = vec4(col, 1.0);
        }
      `
    });
    envScene.add(new THREE.Mesh(envGeo, envMat));
    const envRT = pcbPmrem.fromScene(envScene, 0.04);
    pcbScene.environment = envRT.texture;

    // Lighting
    pcbScene.add(new THREE.AmbientLight(0xffffff, 0.3));
    const pcbKeyLight = new THREE.DirectionalLight(0xffffff, 1.2);
    pcbKeyLight.position.set(3, 6, 4);
    pcbKeyLight.castShadow = true;
    pcbKeyLight.shadow.mapSize.set(1024, 1024);
    pcbKeyLight.shadow.camera.near = 0.1;
    pcbKeyLight.shadow.camera.far = 30;
    pcbKeyLight.shadow.bias = -0.002;
    pcbKeyLight.shadow.radius = 4;
    pcbScene.add(pcbKeyLight);
    const pcbFillLight = new THREE.DirectionalLight(0xe0e8ff, 0.6);
    pcbFillLight.position.set(-3, 3, -2);
    pcbScene.add(pcbFillLight);
    const pcbRimLight = new THREE.DirectionalLight(0xffffff, 0.4);
    pcbRimLight.position.set(0, 2, -5);
    pcbScene.add(pcbRimLight);
    pcbScene.add(new THREE.HemisphereLight(0x222233, 0x111111, 0.3));

    const pcbHighlightMat = new THREE.MeshStandardMaterial({
      color: 0xff3333, roughness: 0.35, metalness: 0.1,
      emissive: 0x441111, emissiveIntensity: 0.5
    });

    function formatComponentName(refDes: string): string {
      if (refDes.startsWith('C')) return `C${refDes.slice(1)} — Capacitor`;
      if (refDes.startsWith('R')) return `R${refDes.slice(1)} — Resistor`;
      if (refDes.startsWith('D')) return `D${refDes.slice(1)} — Diode`;
      if (refDes.startsWith('U')) return `U${refDes.slice(1)} — IC`;
      if (refDes.startsWith('SW')) return `SW${refDes.slice(2)} — Switch`;
      if (refDes.startsWith('J')) return `J${refDes.slice(1)} — Connector`;
      return refDes;
    }

    const pcbMeshes: THREE.Mesh[] = [];
    const pcbOriginalMats = new Map<THREE.Mesh, THREE.Material | THREE.Material[]>();
    const pcbMeshNames = new Map<THREE.Mesh, string>();
    const pcbMeshToGroup = new Map<THREE.Mesh, string>();
    const pcbGroupMeshes = new Map<string, THREE.Mesh[]>();
    const pcbRaycaster = new THREE.Raycaster();
    const pcbMouse = new THREE.Vector2();

    let pcbPivot: THREE.Group | null = null;
    const pcbLoader = new GLTFLoader();
    let pcbModelLoaded = false;
    function loadPcbModel() {
      if (pcbModelLoaded) return;
      pcbModelLoaded = true;
      pcbLoader.load('/models/orbiton.glb', (gltf) => {
        const model = gltf.scene;

        model.traverse((node: any) => {
          if (node.isMesh) {
            node.castShadow = true;
            node.receiveShadow = true;
            const mats = Array.isArray(node.material) ? node.material : [node.material];
            mats.forEach((mat: any) => {
              if (mat.isMeshStandardMaterial || mat.isMeshPhysicalMaterial) {
                mat.envMapIntensity = 0.4;
                mat.needsUpdate = true;
              } else if (mat.isMeshPhongMaterial || mat.isMeshLambertMaterial) {
                node.material = new THREE.MeshStandardMaterial({
                  color: mat.color || 0x888888,
                  roughness: 0.5,
                  metalness: mat.shininess ? Math.min(mat.shininess / 200, 0.8) : 0.1,
                  map: mat.map || null,
                  normalMap: mat.normalMap || null,
                  envMapIntensity: 0.4,
                });
              }
            });
          }
        });

        const pcbGreen = new THREE.Color(0x008C4A);
        model.traverse((node: any) => {
          if (node.isMesh) {
            const mats = Array.isArray(node.material) ? node.material : [node.material];
            mats.forEach((mat: any) => {
              if (mat.color) {
                const hsl = { h: 0, s: 0, l: 0 };
                mat.color.getHSL(hsl);
                if (hsl.h > 0.2 && hsl.h < 0.5 && hsl.s > 0.1) {
                  mat.color.copy(pcbGreen);
                  mat.needsUpdate = true;
                }
              }
            });
          }
        });

        model.children.forEach(child => {
          const name = child.name;
          if (!name || name.startsWith('=>')) return;
          const displayName = formatComponentName(name);
          child.traverse(descendant => {
            if ((descendant as THREE.Mesh).isMesh) {
              const m = descendant as THREE.Mesh;
              pcbOriginalMats.set(m, m.material);
              pcbMeshNames.set(m, displayName);
              pcbMeshToGroup.set(m, name);
              if (!pcbGroupMeshes.has(name)) pcbGroupMeshes.set(name, []);
              pcbGroupMeshes.get(name)!.push(m);
              pcbMeshes.push(m);
            }
          });
        });

        const box = new THREE.Box3().setFromObject(model);
        const center = box.getCenter(new THREE.Vector3());
        model.position.set(-center.x, -center.y, -center.z);

        pcbPivot = new THREE.Group();
        pcbPivot.add(model);
        pcbScene.add(pcbPivot);

        const finalBox = new THREE.Box3().setFromObject(pcbPivot);
        const finalCenter = finalBox.getCenter(new THREE.Vector3());
        const finalSize = finalBox.getSize(new THREE.Vector3());
        pcbControls.target.copy(finalCenter);
        const dist = Math.max(finalSize.x, finalSize.y, finalSize.z) * 2.0;
        pcbCamera.position.set(finalCenter.x + dist * 0.35, finalCenter.y + dist * 0.55, finalCenter.z + dist * 0.45);
        pcbControls.update();

        pcbLoading.style.opacity = '0';
        pcbLoading.style.transition = 'opacity 0.5s';
        setTimeout(() => { pcbLoading.style.display = 'none'; }, 500);
      },
      undefined,
      (error) => { console.error('Orbiton PCB load error:', error); }
      );
    }
    const pcbLoadObserver = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { loadPcbModel(); pcbLoadObserver.disconnect(); }
    }, { rootMargin: '200px' });
    pcbLoadObserver.observe(pcbContainer);

    // Hover highlighting
    let pcbCurrentGroup: string | null = null;

    function pcbHighlightGroup(groupName: string) {
      pcbMeshes.forEach(m => {
        const orig = pcbOriginalMats.get(m);
        if (orig) m.material = orig as THREE.Material;
      });
      const meshes = pcbGroupMeshes.get(groupName);
      if (meshes) meshes.forEach(m => { m.material = pcbHighlightMat; });
    }

    function pcbClearHighlight() {
      pcbMeshes.forEach(m => {
        const orig = pcbOriginalMats.get(m);
        if (orig) m.material = orig as THREE.Material;
      });
    }

    pcbCanvas.addEventListener('mousemove', (e) => {
      const rect = pcbCanvas.getBoundingClientRect();
      pcbMouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      pcbMouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

      pcbRaycaster.setFromCamera(pcbMouse, pcbCamera);
      const intersects = pcbRaycaster.intersectObjects(pcbMeshes, false);

      const containerRect = pcbContainer.getBoundingClientRect();
      const cx = e.clientX - containerRect.left;
      const cy = e.clientY - containerRect.top;
      pcbTooltip.style.left = (cx + 16) + 'px';
      pcbTooltip.style.top = (cy - 10) + 'px';

      if (intersects.length > 0) {
        const hit = intersects[0].object as THREE.Mesh;
        const groupName = pcbMeshToGroup.get(hit) || null;
        if (groupName && groupName !== pcbCurrentGroup) {
          pcbCurrentGroup = groupName;
          pcbHighlightGroup(groupName);
          pcbTooltipTitle.textContent = pcbMeshNames.get(hit) || hit.name;
          pcbTooltip.style.opacity = '1';
        }
        pcbCanvas.style.cursor = 'pointer';
      } else {
        if (pcbCurrentGroup) {
          pcbCurrentGroup = null;
          pcbClearHighlight();
          pcbTooltip.style.opacity = '0';
        }
        pcbCanvas.style.cursor = 'grab';
      }
    });

    pcbCanvas.addEventListener('mouseleave', () => {
      if (pcbCurrentGroup) {
        pcbCurrentGroup = null;
        pcbClearHighlight();
      }
      pcbTooltip.style.opacity = '0';
      pcbCanvas.style.cursor = 'grab';
    });

    // Animation loop (continuous auto-rotate, pauses when off-screen)
    const pcbWorldY = new THREE.Vector3(0, 1, 0);
    let pcbVisible = false;
    const PCB_ROTATE_MAX = 0.008;
    let pcbRotateSpeed = PCB_ROTATE_MAX;
    let pcbHovered = false;
    pcbCanvas.addEventListener('mouseenter', () => { pcbHovered = true; });
    pcbCanvas.addEventListener('mouseleave', () => { pcbHovered = false; });
    new IntersectionObserver(([e]) => { pcbVisible = e.isIntersecting; }, { threshold: 0 }).observe(pcbContainer);
    function pcbAnimate() {
      requestAnimationFrame(pcbAnimate);
      if (!pcbVisible) return;
      const target = pcbHovered ? 0 : PCB_ROTATE_MAX;
      pcbRotateSpeed += (target - pcbRotateSpeed) * 0.05;
      if (pcbPivot && pcbRotateSpeed > 0.0001) {
        pcbPivot.rotateOnWorldAxis(pcbWorldY, pcbRotateSpeed);
      }
      pcbControls.update();
      pcbRenderer.render(pcbScene, pcbCamera);
    }
    pcbAnimate();

    new ResizeObserver(() => {
      const w = pcbContainer.clientWidth;
      const h = pcbContainer.clientHeight;
      pcbCamera.aspect = w / h;
      pcbCamera.updateProjectionMatrix();
      pcbRenderer.setSize(w, h);
    }).observe(pcbContainer);

    } // end desktop-only guard
  </script>
</Layout>
