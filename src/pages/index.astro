  <!-- Three.js Script — Rocket Viewer in Vehicle Section -->
  <script>
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    // Component group definitions — keyed by group ID
    const componentInfo: Record<string, { name: string; desc: string; link?: string; linkLabel?: string; onNavigate?: () => void }> = {
      legs: {
        name: 'Landing Legs',
        desc: '4 deployable landing legs with spring-loaded deployment mechanism. 3D printed (PLA/PETG).',
      },
      avionics: {
        name: 'Avionics Bay',
        desc: 'Aurora PV1 — STM32H7 @ 600MHz, BMI055/088 IMU, BMP390L baro, 8 servo outputs, 4 pyro channels.',
        link: '#avionics',
        linkLabel: 'View Avionics →',
        onNavigate: () => {
          // Click the PV1 tab when navigating
          const pv1Tab = document.querySelector('[data-avionics="pv1"]') as HTMLElement;
          if (pv1Tab) pv1Tab.click();
        },
      },
      tvc: {
        name: 'TVC Mount',
        desc: 'Dual motor thrust vector control. ±5° actuation via MKS HV393i servos at 0.05s/5°. MATLAB/Simulink characterized.',
        link: '#hardware',
        linkLabel: 'View Hardware →',
      },
      nosecone: {
        name: 'Nosecone',
        desc: '3D printed nosecone with aerodynamic profile for stable ascent.',
      },
    };

    const canvas = document.getElementById('rocket-canvas') as HTMLCanvasElement;
    const container = document.getElementById('rocket-container')!;
    const loadingOverlay = document.getElementById('loading-overlay')!;
    const hoverTooltip = document.getElementById('hover-tooltip')!;
    const tooltipTitle = document.getElementById('tooltip-title')!;
    const tooltipDesc = document.getElementById('tooltip-desc')!;
    const tooltipLink = document.getElementById('tooltip-link')!;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.01, 100);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.5;
    controls.enablePan = false;
    controls.enableZoom = false;
    controls.minPolarAngle = Math.PI * 0.2;
    controls.maxPolarAngle = Math.PI * 0.8;

    // Lighting
    scene.add(new THREE.AmbientLight(0xffffff, 0.8));
    const keyLight = new THREE.DirectionalLight(0xffffff, 1.0);
    keyLight.position.set(3, 4, 2);
    scene.add(keyLight);
    const fillLight = new THREE.DirectionalLight(0xffffff, 0.4);
    fillLight.position.set(-2, 1, -1);
    scene.add(fillLight);

    // Materials
    const tubeMaterial = new THREE.MeshPhongMaterial({
      color: 0x888888, transparent: true, opacity: 0.06,
      side: THREE.DoubleSide, depthWrite: false,
    });
    const internalMaterial = new THREE.MeshPhongMaterial({
      color: 0x333333, shininess: 40, specular: 0x222222,
    });
    const internalHighlightMaterial = new THREE.MeshPhongMaterial({
      color: 0xcc0000, shininess: 60, emissive: 0x220000,
    });

    // Mesh tracking
    const allMeshes: THREE.Mesh[] = [];
    const airframeMeshes = new Set<THREE.Mesh>();
    const raycastTargets: THREE.Mesh[] = []; // excludes airframe
    const meshToGroup = new Map<THREE.Mesh, string>(); // mesh → group ID
    const groupMeshes = new Map<string, THREE.Mesh[]>(); // group ID → meshes
    const originalMaterials = new Map<THREE.Mesh, THREE.Material>();

    // White default material for avionics/TVC (idle state)
    const whiteIdleMaterial = new THREE.MeshPhongMaterial({
      color: 0xcccccc, shininess: 50, specular: 0x444444,
    });

    // Tag all descendant meshes of a node with a group
    function tagDescendants(node: THREE.Object3D, group: string) {
      node.traverse((child) => {
        if ((child as THREE.Mesh).isMesh) {
          const m = child as THREE.Mesh;
          if (!meshToGroup.has(m)) {
            meshToGroup.set(m, group);
            if (!groupMeshes.has(group)) groupMeshes.set(group, []);
            groupMeshes.get(group)!.push(m);
          }
        }
      });
    }

    // Classify nodes — check name prefixes, must check more specific names first
    // Note: GLTF from Onshape uses underscores in names (e.g. LLL_Mount_Assembly_<1>)
    function classifyNodeName(name: string): string | null {
      if (name === 'airframe' || name === 'occurrence_of_airframe') return 'airframe';
      if (name === 'nosecone' || name === 'occurrence_of_nosecone') return 'nosecone';
      // LLL_Mount_Assembly MUST come before Mount_Assembly
      if (name.startsWith('LLL_Mount_Assembly')) return 'avionics';
      if (name.startsWith('Mount_Assembly')) return 'tvc';
      if (name.startsWith('SG90')) return 'tvc';
      if (name.startsWith('R2_Landing_Leg') || name.startsWith('R2_Bottom_Strut')) return 'legs';
      if (name.startsWith('Upper_Strut')) return 'legs';
      if (name.includes('Top_leg_strut')) return 'legs';
      return null;
    }

    const raycaster = new THREE.Raycaster();
    const mouse = new THREE.Vector2();

    const loader = new GLTFLoader();
    loader.load(
      '/models/rocket.gltf',
      (gltf) => {
        const model = gltf.scene;

        // Step 1: Find assembly nodes by name and tag all their descendant meshes
        const processNode = (node: THREE.Object3D) => {
          const group = classifyNodeName(node.name);
          if (group) {
            console.log(`Tagging "${node.name}" as ${group}`);
            tagDescendants(node, group);
          } else {
            // Only recurse into children if this node wasn't classified
            // (if classified, tagDescendants already handled all descendants)
            node.children.forEach(child => processNode(child));
          }
        };
        processNode(model);

        // Step 2: Collect all meshes and apply materials
        model.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            const m = child as THREE.Mesh;
            const group = meshToGroup.get(m) || null;
            const isAirframe = group === 'airframe';

            // Avionics and TVC start white (idle highlight)
            let mat: THREE.Material;
            if (isAirframe) {
              mat = tubeMaterial.clone();
            } else if (group === 'avionics' || group === 'tvc' || group === 'legs') {
              mat = whiteIdleMaterial.clone();
            } else {
              mat = internalMaterial.clone();
            }

            originalMaterials.set(m, mat);
            m.material = mat;
            allMeshes.push(m);

            if (isAirframe) {
              airframeMeshes.add(m);
              m.renderOrder = 1;
            } else {
              raycastTargets.push(m);
            }
          }
        });

        console.log('Group counts:', [...groupMeshes.entries()].map(([k, v]) => `${k}: ${v.length}`).join(', '));
        console.log('Total meshes:', allMeshes.length);
        console.log('Unclassified:', allMeshes.filter(m => !meshToGroup.has(m)).length);

        // Center and orient
        const preBox = new THREE.Box3().setFromObject(model);
        const preCenter = preBox.getCenter(new THREE.Vector3());
        model.position.set(-preCenter.x, -preCenter.y, -preCenter.z);

        const pivot = new THREE.Group();
        pivot.add(model);
        const preSize = preBox.getSize(new THREE.Vector3());
        if (preSize.x > preSize.y && preSize.x > preSize.z) {
          pivot.rotation.z = Math.PI / 2;
        } else if (preSize.z > preSize.y && preSize.z > preSize.x) {
          pivot.rotation.x = -Math.PI / 2;
        }
        scene.add(pivot);

        // Camera setup — focus on bottom third, zoomed in
        const box = new THREE.Box3().setFromObject(pivot);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        const bottomThirdCenterY = box.min.y + size.y * 0.2;
        controls.target.set(center.x, bottomThirdCenterY, center.z);
        const dist = 0.9;
        camera.position.set(center.x + dist, bottomThirdCenterY + 0.05, center.z + dist * 0.4);
        controls.update();

        // Create invisible bounding-box hit areas for avionics and TVC
        // so the entire assembly volume is hoverable
        ['avionics', 'tvc'].forEach((groupId) => {
          const meshes = groupMeshes.get(groupId);
          if (!meshes || meshes.length === 0) return;
          const groupBox = new THREE.Box3();
          meshes.forEach((m) => groupBox.expandByObject(m));
          const groupSize = groupBox.getSize(new THREE.Vector3());
          const groupCenter = groupBox.getCenter(new THREE.Vector3());
          const pad = 0.03;
          const hitGeo = new THREE.BoxGeometry(groupSize.x + pad, groupSize.y + pad, groupSize.z + pad);
          const hitMat = new THREE.MeshBasicMaterial({ visible: false });
          const hitMesh = new THREE.Mesh(hitGeo, hitMat);
          hitMesh.position.copy(groupCenter);
          scene.add(hitMesh);
          raycastTargets.push(hitMesh);
          meshToGroup.set(hitMesh, groupId);
        });

        loadingOverlay.style.opacity = '0';
        loadingOverlay.style.transition = 'opacity 0.5s';
        setTimeout(() => { loadingOverlay.style.display = 'none'; }, 500);
      },
      undefined,
      (err) => {
        console.error('Failed to load model:', err);
        loadingOverlay.innerHTML = '<p class="text-red-500">Failed to load 3D model</p>';
      }
    );

    // Raycasting hover
    let currentGroup: string | null = null;

    function highlightGroup(group: string) {
      // Reset everything to original
      allMeshes.forEach((mesh) => {
        if (!airframeMeshes.has(mesh)) {
          mesh.material = originalMaterials.get(mesh) || internalMaterial;
        }
      });
      // Highlight the hovered group red
      const meshes = groupMeshes.get(group);
      if (meshes) {
        meshes.forEach((m) => { m.material = internalHighlightMaterial; });
      }
    }

    function clearHighlight() {
      allMeshes.forEach((mesh) => {
        mesh.material = originalMaterials.get(mesh) || internalMaterial;
      });
    }

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

      raycaster.setFromCamera(mouse, camera);
      const intersects = raycaster.intersectObjects(raycastTargets, false);

      // Position tooltip to the LEFT of cursor on desktop
      const containerRect = container.getBoundingClientRect();
      const cursorX = e.clientX - containerRect.left;
      const cursorY = e.clientY - containerRect.top;
      // Place tooltip to the left, or right if too close to left edge
      const tooltipW = 230;
      if (cursorX > tooltipW + 20) {
        hoverTooltip.style.left = (cursorX - tooltipW - 12) + 'px';
      } else {
        hoverTooltip.style.left = (cursorX + 16) + 'px';
      }
      hoverTooltip.style.top = (cursorY - 10) + 'px';

      if (intersects.length > 0) {
        const hit = intersects[0].object as THREE.Mesh;
        const group = meshToGroup.get(hit) || null;

        if (group && group !== currentGroup) {
          currentGroup = group;
          highlightGroup(group);

          const info = componentInfo[group];
          if (info) {
            tooltipTitle.textContent = info.name;
            tooltipDesc.textContent = info.desc;
            if (info.linkLabel) {
              tooltipLink.textContent = info.linkLabel;
              tooltipLink.classList.remove('hidden');
            } else {
              tooltipLink.classList.add('hidden');
            }
            hoverTooltip.style.opacity = '1';
          }
        }
        canvas.style.cursor = 'pointer';
      } else {
        if (currentGroup !== null) {
          currentGroup = null;
          clearHighlight();
          hoverTooltip.style.opacity = '0';
        }
        canvas.style.cursor = 'grab';
      }
    });

    canvas.addEventListener('mouseleave', () => {
      currentGroup = null;
      clearHighlight();
      hoverTooltip.style.opacity = '0';
      canvas.style.cursor = 'grab';
    });

    // Click to navigate to section
    canvas.addEventListener('click', () => {
      if (currentGroup) {
        const info = componentInfo[currentGroup];
        if (info?.link) {
          if (info.onNavigate) info.onNavigate();
          document.querySelector(info.link)?.scrollIntoView({ behavior: 'smooth' });
        }
      }
    });

    // Animation loop
    function animate() {
      requestAnimationFrame(animate);
      controls.update();
      renderer.render(scene, camera);
    }
    animate();

    // Resize
    window.addEventListener('resize', () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });

    // Navbar scroll effect — starts grey/translucent, fades to solid black
    const navbar = document.getElementById('navbar')!;
    navbar.style.backgroundColor = 'rgba(30, 30, 30, 0.5)';
    navbar.style.backdropFilter = 'blur(4px)';
    window.addEventListener('scroll', () => {
      const scrollFraction = Math.min(window.scrollY / 400, 1);
      const opacity = 0.5 + scrollFraction * 0.5;
      const bg = Math.round(30 - scrollFraction * 20); // 30 -> 10
      const blur = 4 + scrollFraction * 8; // 4px -> 12px
      navbar.style.backgroundColor = `rgba(${bg}, ${bg}, ${bg}, ${opacity})`;
      navbar.style.backdropFilter = `blur(${blur}px)`;
      if (scrollFraction > 0.1) {
        navbar.style.borderBottom = `1px solid rgba(255,255,255,${scrollFraction * 0.05})`;
      } else {
        navbar.style.borderBottom = 'none';
      }
    });

    // Mobile menu
    document.getElementById('mobile-menu-btn')!.addEventListener('click', () => {
      document.getElementById('mobile-menu')!.classList.toggle('hidden');
    });
    document.querySelectorAll('#mobile-menu a').forEach((a) => {
      a.addEventListener('click', () => { document.getElementById('mobile-menu')!.classList.add('hidden'); });
    });

    // Avionics tab switching
    const avionicsTabs = document.querySelectorAll('.avionics-tab');
    const avionicsPanels = document.querySelectorAll('.avionics-panel');
    avionicsTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.avionics;
        // Update tab styles
        avionicsTabs.forEach((t) => {
          const el = t as HTMLElement;
          if (el.dataset.avionics === target) {
            el.classList.remove('bg-[var(--color-surface)]', 'border-[var(--color-surface-border)]');
            el.classList.add('bg-[var(--color-accent)]/10', 'border-[var(--color-accent)]/40');
          } else {
            el.classList.remove('bg-[var(--color-accent)]/10', 'border-[var(--color-accent)]/40');
            el.classList.add('bg-[var(--color-surface)]', 'border-[var(--color-surface-border)]');
          }
        });
        // Show/hide panels
        avionicsPanels.forEach((p) => {
          const panel = p as HTMLElement;
          if (panel.id === `panel-${target}`) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    // Carousel
    const carouselTrack = document.getElementById('carousel-track')!;
    const carouselDots = document.querySelectorAll('.carousel-dot');
    const slideCount = 4;
    let currentSlide = 0;

    function goToSlide(index: number) {
      currentSlide = ((index % slideCount) + slideCount) % slideCount;
      carouselTrack.style.transform = `translateX(-${currentSlide * 100}%)`;
      carouselDots.forEach((dot, i) => {
        if (i === currentSlide) {
          dot.classList.remove('bg-[var(--color-surface-border)]');
          dot.classList.add('bg-[var(--color-accent)]');
        } else {
          dot.classList.remove('bg-[var(--color-accent)]');
          dot.classList.add('bg-[var(--color-surface-border)]');
        }
      });
    }

    document.getElementById('carousel-prev')!.addEventListener('click', () => goToSlide(currentSlide - 1));
    document.getElementById('carousel-next')!.addEventListener('click', () => goToSlide(currentSlide + 1));
    carouselDots.forEach((dot) => {
      dot.addEventListener('click', () => goToSlide(Number((dot as HTMLElement).dataset.slide)));
    });

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.opacity = '1';
          (entry.target as HTMLElement).style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach((el) => {
      (el as HTMLElement).style.opacity = '0';
      (el as HTMLElement).style.transform = 'translateY(30px)';
      (el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });
  </script>

  <!-- TVC Mount 3D Viewer Script -->
  <script>
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    const tvcContainer = document.getElementById('tvc-viewer')!;
    const tvcCanvas = document.getElementById('tvc-canvas') as HTMLCanvasElement;
    const tvcLoading = document.getElementById('tvc-loading')!;
    const tvcTooltip = document.getElementById('tvc-tooltip')!;
    const tvcTooltipTitle = document.getElementById('tvc-tooltip-title')!;

    const tvcScene = new THREE.Scene();
    const tvcCamera = new THREE.PerspectiveCamera(35, 1, 0.01, 10);
    const tvcRenderer = new THREE.WebGLRenderer({ canvas: tvcCanvas, antialias: true, alpha: true });
    tvcRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    tvcRenderer.setSize(tvcContainer.clientWidth, tvcContainer.clientHeight);

    const tvcControls = new OrbitControls(tvcCamera, tvcCanvas);
    tvcControls.enableDamping = true;
    tvcControls.dampingFactor = 0.05;
    tvcControls.enablePan = false;

    // Lighting
    tvcScene.add(new THREE.AmbientLight(0xffffff, 0.6));
    const tvcDirLight = new THREE.DirectionalLight(0xffffff, 1.0);
    tvcDirLight.position.set(2, 3, 2);
    tvcScene.add(tvcDirLight);
    const tvcDirLight2 = new THREE.DirectionalLight(0xffffff, 0.4);
    tvcDirLight2.position.set(-2, 1, -1);
    tvcScene.add(tvcDirLight2);

    // Materials
    const tvcRedMat = new THREE.MeshPhongMaterial({ color: 0xcc2222, shininess: 60, specular: 0x444444 });
    const tvcBeigeMat = new THREE.MeshPhongMaterial({ color: 0xd4b896, shininess: 30, specular: 0x222222 });
    const tvcWhiteMat = new THREE.MeshPhongMaterial({ color: 0xe8e8e8, shininess: 50, specular: 0x444444 });
    const tvcBlackMat = new THREE.MeshPhongMaterial({ color: 0x1a1a1a, shininess: 40, specular: 0x333333 });
    const tvcHighlightMat = new THREE.MeshPhongMaterial({ color: 0xff4444, shininess: 80, emissive: 0x331111, specular: 0x666666 });

    // Classify TVC parts by node name (uses underscores from Onshape GLTF)
    type TvcCategory = 'servo' | 'motor' | 'sleeve' | 'mount';
    function classifyTvcNode(name: string): TvcCategory | null {
      if (name.includes('HV93i')) return 'servo';
      if (name.includes('24mm_E12')) return 'motor';
      if (name.includes('E12_Sleeve')) return 'sleeve';
      if (name.includes('Gimbal_Mount') || name.includes('Motor_Tube')) return 'mount';
      return null;
    }

    const tvcCategoryInfo: Record<TvcCategory, { mat: THREE.Material; displayName: (name: string) => string }> = {
      servo: { mat: tvcRedMat, displayName: () => 'MKS HV93i Servo' },
      motor: { mat: tvcBeigeMat, displayName: () => 'Estes E12 Motor' },
      sleeve: { mat: tvcWhiteMat, displayName: (name) => name.replace(/^occurrence_of_/, '').replace(/_\d+$/, '').replace(/_/g, ' ') },
      mount: { mat: tvcBlackMat, displayName: (name) => name.replace(/^occurrence_of_/, '').replace(/_\d+$/, '').replace(/_/g, ' ') },
    };

    const tvcMeshes: THREE.Mesh[] = [];
    const tvcOriginalMats = new Map<THREE.Mesh, THREE.Material>();
    const tvcMeshNames = new Map<THREE.Mesh, string>();
    const tvcMeshToGroup = new Map<THREE.Mesh, string>(); // maps mesh to parent group name
    const tvcGroupMeshes = new Map<string, THREE.Mesh[]>();

    const tvcRaycaster = new THREE.Raycaster();
    const tvcMouse = new THREE.Vector2();

    function tagTvcDescendants(node: THREE.Object3D, category: TvcCategory, groupName: string) {
      node.traverse((child) => {
        if ((child as THREE.Mesh).isMesh) {
          const m = child as THREE.Mesh;
          if (!tvcMeshToGroup.has(m)) {
            const info = tvcCategoryInfo[category];
            m.material = info.mat.clone();
            tvcOriginalMats.set(m, m.material as THREE.Material);
            tvcMeshNames.set(m, info.displayName(groupName));
            tvcMeshToGroup.set(m, groupName);
            if (!tvcGroupMeshes.has(groupName)) tvcGroupMeshes.set(groupName, []);
            tvcGroupMeshes.get(groupName)!.push(m);
            tvcMeshes.push(m);
          }
        }
      });
    }

    const tvcLoader = new GLTFLoader();
    tvcLoader.load('/models/tvc-mount.gltf', (gltf) => {
      const model = gltf.scene;

      // Top-down classification: walk tree, tag descendants when we hit a named assembly
      const processTvcNode = (node: THREE.Object3D) => {
        const category = classifyTvcNode(node.name);
        if (category) {
          tagTvcDescendants(node, category, node.name);
        } else {
          node.children.forEach(child => processTvcNode(child));
        }
      };
      processTvcNode(model);
      // console.log('TVC groups:', [...tvcGroupMeshes.entries()].map(([k, v]) => `${k}: ${v.length}`).join(', '));

      // Center and orient
      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      model.position.set(-center.x, -center.y, -center.z);

      const pivot = new THREE.Group();
      pivot.add(model);
      const size = box.getSize(new THREE.Vector3());
      // Rotate if needed so it stands upright
      if (size.x > size.y && size.x > size.z) {
        pivot.rotation.z = Math.PI / 2;
      } else if (size.z > size.y && size.z > size.x) {
        pivot.rotation.x = -Math.PI / 2;
      }
      tvcScene.add(pivot);

      const finalBox = new THREE.Box3().setFromObject(pivot);
      const finalCenter = finalBox.getCenter(new THREE.Vector3());
      const finalSize = finalBox.getSize(new THREE.Vector3());
      tvcControls.target.copy(finalCenter);
      const dist = Math.max(finalSize.x, finalSize.y, finalSize.z) * 2.5;
      tvcCamera.position.set(finalCenter.x + dist * 0.6, finalCenter.y + dist * 0.3, finalCenter.z + dist * 0.6);
      tvcControls.update();

      tvcLoading.style.opacity = '0';
      tvcLoading.style.transition = 'opacity 0.5s';
      setTimeout(() => { tvcLoading.style.display = 'none'; }, 500);
    },
    undefined,
    (error) => { console.error('TVC model load error:', error); }
    );

    // Hover — highlight entire group (all meshes sharing same parent part)
    let tvcCurrentGroup: string | null = null;

    function tvcHighlightGroup(groupName: string) {
      // Restore all to original
      tvcMeshes.forEach(m => { m.material = tvcOriginalMats.get(m) || tvcBlackMat; });
      // Highlight group
      const meshes = tvcGroupMeshes.get(groupName);
      if (meshes) meshes.forEach(m => { m.material = tvcHighlightMat; });
    }

    function tvcClearHighlight() {
      tvcMeshes.forEach(m => { m.material = tvcOriginalMats.get(m) || tvcBlackMat; });
    }

    tvcCanvas.addEventListener('mousemove', (e) => {
      const rect = tvcCanvas.getBoundingClientRect();
      tvcMouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
      tvcMouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;

      tvcRaycaster.setFromCamera(tvcMouse, tvcCamera);
      const intersects = tvcRaycaster.intersectObjects(tvcMeshes, false);

      const containerRect = tvcContainer.getBoundingClientRect();
      const cx = e.clientX - containerRect.left;
      const cy = e.clientY - containerRect.top;
      tvcTooltip.style.left = (cx + 16) + 'px';
      tvcTooltip.style.top = (cy - 10) + 'px';

      if (intersects.length > 0) {
        const hit = intersects[0].object as THREE.Mesh;
        const groupName = tvcMeshToGroup.get(hit) || null;
        if (groupName && groupName !== tvcCurrentGroup) {
          tvcCurrentGroup = groupName;
          tvcHighlightGroup(groupName);
          tvcTooltipTitle.textContent = tvcMeshNames.get(hit) || hit.name;
          tvcTooltip.style.opacity = '1';
        }
        tvcCanvas.style.cursor = 'pointer';
      } else {
        if (tvcCurrentGroup) {
          tvcCurrentGroup = null;
          tvcClearHighlight();
          tvcTooltip.style.opacity = '0';
        }
        tvcCanvas.style.cursor = 'grab';
      }
    });

    tvcCanvas.addEventListener('mouseleave', () => {
      if (tvcCurrentGroup) {
        tvcCurrentGroup = null;
        tvcClearHighlight();
      }
      tvcTooltip.style.opacity = '0';
      tvcCanvas.style.cursor = 'grab';
    });

    // Animation loop
    function tvcAnimate() {
      requestAnimationFrame(tvcAnimate);
      tvcControls.update();
      tvcRenderer.render(tvcScene, tvcCamera);
    }
    tvcAnimate();

    // Resize
    new ResizeObserver(() => {
      const w = tvcContainer.clientWidth;
      const h = tvcContainer.clientHeight;
      tvcCamera.aspect = w / h;
      tvcCamera.updateProjectionMatrix();
      tvcRenderer.setSize(w, h);
    }).observe(tvcContainer);
  </script>
</Layout>
